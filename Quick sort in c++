#include <iostream>
using namespace std;

void quick(int arr[], int low, int high)
{
    int i = low, j = high;
    int pivot = arr[(low + high) / 2];
    int temp;

    while (i <= j)
    {
        while (arr[i] < pivot)
            i++;
        while (arr[j] > pivot)
            j--;

        if (i <= j)
        {
            temp = arr[i];
            arr[i] = arr[j];
            arr[j] = temp;
            i++;
            j--;
        }
    }

    if (low < j)
        quick(arr, low, j);
    if (i < high)
        quick(arr, i, high);
}

int main()
{
    int arr[100], n, i;

    cout << "Enter number of elements: ";
    cin >> n;

    cout << "Enter elements:\n";
    for (i = 0; i < n; i++)
        cin >> arr[i];

    quick(arr, 0, n - 1);

    cout << "Sorted array: ";
    for (i = 0; i < n; i++)
        cout << arr[i] << " ";

    return 0;
}
